    "@caixa/ui": "workspace:*",
    "@caixa/validators": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "@vercel/blob": "^2.3.3",
    "lucide-react": "^0.474.0",
    "next": "^16.0.9",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "superjson": "2.2.3",
    "zod": "catalog:",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@caixa/eslint-config": "workspace:*",
    "@caixa/prettier-config": "workspace:*",
